###############################################################################
# easy-dataspace-deploy  –  Environment Configuration
###############################################################################

# =============================================================================
# IMAGES
# =============================================================================
GITHUB_OWNER=mjanez
GHCR_IMAGE_TAG=latest

KEYCLOAK_IMAGE=ghcr.io/${GITHUB_OWNER}/dataspace-portal-keycloak:${GHCR_IMAGE_TAG}
PORTAL_BACKEND_IMAGE=ghcr.io/${GITHUB_OWNER}/dataspace-portal-backend:${GHCR_IMAGE_TAG}
PORTAL_FRONTEND_IMAGE=ghcr.io/${GITHUB_OWNER}/dataspace-portal-frontend:${GHCR_IMAGE_TAG}
CRAWLER_IMAGE=ghcr.io/${GITHUB_OWNER}/dataspace-portal-crawler:${GHCR_IMAGE_TAG}
CADDY_IMAGE=caddy:2.8
OAUTH2_PROXY_IMAGE=quay.io/oauth2-proxy/oauth2-proxy:v7.5.0
POSTGRES_IMAGE=postgres:17-alpine
EDC_IMAGE=ghcr.io/sovity/edc-ce:16.5.0
EDC_UI_IMAGE=ghcr.io/sovity/edc-ce-ui:16.5.0

# =============================================================================
# BRANDING / FLAVOUR
# =============================================================================
FRONTEND_BRAND_LOGO_URL=
FRONTEND_BRAND_LOGO_SMALL_URL=
FRONTEND_BRAND_LOGO_LOGIN_URL=
FRONTEND_BRAND_COPYRIGHT=
FRONTEND_PORTAL_DISPLAY_NAME=My Data Space Portal
FRONTEND_DATASPACE_SHORT_NAME=MyDS

# =============================================================================
# PORTS
# =============================================================================
PORTAL_PORT=18000
KEYCLOAK_PORT=18080
CRAWLER_PORT=18400
CONNECTOR_A_PORT=18100
CONNECTOR_B_PORT=18200
CONNECTOR_C_PORT=18300

# =============================================================================
# URLs
# =============================================================================
PORTAL_PUBLIC_URL=http://portal.localhost:18000
KEYCLOAK_PUBLIC_URL=http://keycloak.localhost:18080
CRAWLER_PUBLIC_URL=http://crawler.localhost:18400
CONNECTOR_A_PUBLIC_URL=http://connector-a.localhost:18100
CONNECTOR_B_PUBLIC_URL=http://connector-b.localhost:18200
CONNECTOR_C_PUBLIC_URL=http://connector-c.localhost:18300

# =============================================================================
# KEYCLOAK
# =============================================================================
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
KEYCLOAK_REALM=authority-portal

KEYCLOAK_OAUTH2_PROXY_CLIENT_ID=oauth2-proxy
KEYCLOAK_OAUTH2_PROXY_CLIENT_SECRET=oauth2-proxy-client-secret

KEYCLOAK_PORTAL_CLIENT_ID=authority-portal-client
KEYCLOAK_PORTAL_CLIENT_SECRET=authority-portal-client-secret

# =============================================================================
# DATABASES
# =============================================================================
PORTAL_DB_USER=portal
PORTAL_DB_PASSWORD=portal
PORTAL_DB_NAME=authority_portal

CONNECTOR_DB_USER=connector
CONNECTOR_DB_PASSWORD=connector
CONNECTOR_DB_NAME=connector

# =============================================================================
# PORTAL BACKEND
# =============================================================================
PORTAL_BACKEND_LOG_LEVEL=INFO
PORTAL_BACKEND_CONFIG_API_KEY=DefaultConfigApiKey
PORTAL_BACKEND_ORG_PREFIX=BPNL
PORTAL_BACKEND_DEPLOYMENT_ENV=development

# =============================================================================
# DAPS (local Keycloak stub)
# =============================================================================
DAPS_URL=${KEYCLOAK_PUBLIC_URL}/realms/${KEYCLOAK_REALM}/protocol/openid-connect/token
DAPS_TOKEN_URL=${KEYCLOAK_PUBLIC_URL}/realms/${KEYCLOAK_REALM}/protocol/openid-connect/token
DAPS_JWKS_URL=${KEYCLOAK_PUBLIC_URL}/realms/${KEYCLOAK_REALM}/protocol/openid-connect/certs

# =============================================================================
# CRAWLER
# =============================================================================
CRAWLER_PARTICIPANT_ID=BPNL000000.CRAWL01
CRAWLER_DAPS_TOKEN_URL=${DAPS_TOKEN_URL}
CRAWLER_DAPS_JWKS_URL=${DAPS_JWKS_URL}
CRAWLER_CRON_ONLINE_STATUS=*/10 * * * *
CRAWLER_CRON_REFRESH_CATALOG=*/15 * * * *
CRAWLER_DB_POOL_SIZE=5

# =============================================================================
# FRONTEND URLs
# =============================================================================
FRONTEND_LOGIN_URL=${PORTAL_PUBLIC_URL}/oauth2/start?rd=%2F
FRONTEND_LOGOUT_URL=${PORTAL_PUBLIC_URL}/oauth2/sign_out?rd=%2F
FRONTEND_INVALIDATE_SESSION_COOKIES_URL=${PORTAL_PUBLIC_URL}/oauth2/sign_out?rd=%2F
FRONTEND_UPDATE_PASSWORD_URL=${KEYCLOAK_PUBLIC_URL}/realms/${KEYCLOAK_REALM}/account/password

FRONTEND_ACTIVE_PROFILE=default

# =============================================================================
# OAUTH2 PROXY
# =============================================================================
OAUTH2_PROXY_PROVIDER=keycloak-oidc
OAUTH2_PROXY_CLIENT_ID=${KEYCLOAK_OAUTH2_PROXY_CLIENT_ID}
OAUTH2_PROXY_CLIENT_SECRET=${KEYCLOAK_OAUTH2_PROXY_CLIENT_SECRET}
OAUTH2_PROXY_OIDC_ISSUER_URL=${KEYCLOAK_PUBLIC_URL}/realms/${KEYCLOAK_REALM}
OAUTH2_PROXY_REDIRECT_URL=${PORTAL_PUBLIC_URL}/oauth2/callback
OAUTH2_PROXY_EMAIL_DOMAINS=*
OAUTH2_PROXY_COOKIE_SECRET=super-secret-cookie-secret-32b!
OAUTH2_PROXY_COOKIE_SECURE=false
OAUTH2_PROXY_UPSTREAMS=http://portal-caddy:8081
OAUTH2_PROXY_HTTP_ADDRESS=0.0.0.0:8080
OAUTH2_PROXY_SKIP_PROVIDER_BUTTON=true
OAUTH2_PROXY_PASS_ACCESS_TOKEN=true
OAUTH2_PROXY_PASS_AUTHORIZATION_HEADER=true

# =============================================================================
# EDC CONNECTORS
# =============================================================================
EDC_DEPLOYMENT_KIND=connector
EDC_DAPS_TOKEN_URL=${DAPS_TOKEN_URL}
EDC_DAPS_JWKS_URL=${DAPS_JWKS_URL}
EDC_MANAGEMENT_API_KEY=DefaultManagementApiKey

# =============================================================================
# CONNECTOR IDENTITIES
# =============================================================================
CONNECTOR_A_PARTICIPANT_ID=BPNL000001.CONN001
CONNECTOR_B_PARTICIPANT_ID=BPNL000001.CONN002
CONNECTOR_C_PARTICIPANT_ID=BPNL000001.CONN003

# =============================================================================
# CONNECTOR A
# =============================================================================
CONNECTOR_A_TITLE=Connector A
CONNECTOR_A_DESCRIPTION=Demo connector A
CONNECTOR_A_MAINTAINER_URL=http://connector-a.localhost:18100
CONNECTOR_A_COUNTERPARTY_ADDRESS=http://connector-b.localhost:18200/api/v1/dsp

# =============================================================================
# CONNECTOR B
# =============================================================================
CONNECTOR_B_TITLE=Connector B
CONNECTOR_B_DESCRIPTION=Demo connector B
CONNECTOR_B_MAINTAINER_URL=http://connector-b.localhost:18200
CONNECTOR_B_COUNTERPARTY_ADDRESS=http://connector-a.localhost:18100/api/v1/dsp

# =============================================================================
# CONNECTOR C
# =============================================================================
CONNECTOR_C_TITLE=Connector C
CONNECTOR_C_DESCRIPTION=Demo connector C
CONNECTOR_C_MAINTAINER_URL=http://connector-c.localhost:18300
CONNECTOR_C_COUNTERPARTY_ADDRESS=http://connector-a.localhost:18100/api/v1/dsp
